# SEP Engine Environment Configuration Template
# Copy this file to .env and fill in your values

# === API Configuration ===
# Base URL for the SEP API (used by frontend and backend)
SEP_API_URL=http://localhost:8000

# API Bearer token for authentication
SEP_API_BEARER_TOKEN=your_api_bearer_token_here

# === Valkey/Redis Configuration (internal) ===
# Internal Valkey URL for all services
VALKEY_URL=redis://valkey:6379/0

# Valkey password (used to construct URLs if not provided explicitly)
VALKEY_PASSWORD=your_valkey_password_here

# === WebSocket Configuration ===
# WebSocket URL for real-time updates
SEP_WS_URL=ws://localhost:8001

# WebSocket authentication token
SEP_WS_TOKEN=your_ws_token_here

# === OANDA Configuration ===
# OANDA API key/token
OANDA_API_KEY=your_oanda_api_key_here

# OANDA Account ID
OANDA_ACCOUNT_ID=your_account_id_here

# OANDA Environment (practice or live)
OANDA_ENVIRONMENT=practice

# OANDA API URLs (optional, will use defaults based on environment)
OANDA_PRACTICE_API_URL=https://api-fxpractice.oanda.com
OANDA_LIVE_API_URL=https://api-fxtrade.oanda.com
OANDA_PRACTICE_STREAM_URL=https://stream-fxpractice.oanda.com
OANDA_LIVE_STREAM_URL=https://stream-fxtrade.oanda.com

# === Trading Configuration ===
# Enable live trading (0=disabled, 1=enabled)
LIVE_TRADING_ENABLED=0

# Enable auto trading (0=disabled, 1=enabled)
AUTO_TRADING_ENABLED=0

# Kill switch (0=normal, 1=halt all trading)
KILL_SWITCH=0

# === Frontend Configuration ===
# Read-only mode for frontend (0=full access, 1=read-only)
READ_ONLY=0

# Allow kill switch toggle in frontend (0=disabled, 1=enabled)
ALLOW_KILL_TOGGLE=1

# === GPU/Processing Configuration ===
# Manifold device (cpu or gpu)
MANIFOLD_DEVICE=cpu

# GPU worker mode (0=disabled, 1=enabled)
GPU_WORKER=0

# === Portfolio Configuration ===
# Portfolio rebalance threshold (0.02 = 2%)
PORTFOLIO_REBALANCE_THRESHOLD=0.02

# Portfolio reconcile interval in seconds
PORTFOLIO_RECONCILE_SEC=30

# === Risk Configuration ===
# NAV fraction used as margin per trade (0.05 = 5%)
PORTFOLIO_NAV_RISK_PCT=0.05

# Per-position cap mirrors the live portfolio manager sizing ceiling
PM_MAX_PER_POS_PCT=0.05

# Historical max overlap observed in the synced ML-primary exports
PM_ALLOC_TOP_K=12
ALLOC_TOP_K=12
RISK_MAX_TOTAL_POSITIONS=12
RISK_MAX_POSITIONS_PER_PAIR=5
RISK_MAX_NET_UNITS_PER_PAIR=40000

# === Development/Operations ===

# Host role for deployment safety. Use `gpu` on research boxes and `droplet`
# only on the live execution host.
SEP_NODE_ROLE=unknown

# Emergency override for deploy.sh. Leave disabled on normal systems.
SEP_ALLOW_NON_DROPLET_DEPLOY=0

# OANDA environment source (env or account)
OANDA_ENV_SOURCE=account

# Replace default pairs with HOTBAND_PAIRS (0=append, 1=replace)
HOTBAND_REPLACE=0
